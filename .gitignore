*.egg

# Environments
.env
.venv
!.env.example 
venv/
env/
.env
# Data — never commit raw data
data/raw/*
data/processed/*
data/external/*
data/features/*
!data/**/.gitkeep

# Models — never commit large model files
models/trained/*
models/checkpoints/*
!models/**/.gitkeep

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE
.vscode/
.idea/*.swp
*.swo

