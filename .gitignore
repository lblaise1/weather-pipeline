logs/
*.log
*.prof
output/

# MLflow
mlruns/
mlartifacts/

# Postgres data — actual database files
postgres/data/
postgres/

# Virtualenv (this project uses .weather)
.weather/

# dbt artifacts
dbt/my_project/target/
dbt/my_project/logs/
dbt/my_project/dbt_packages/

# Compose backup files
docker-compose copy.yml
docker-compose*.bak

# Airflow runtime
airflow/logs/
