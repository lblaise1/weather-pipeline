# Weatherstack API key — get a free one at https://weatherstack.com
# Free tier: 100 calls/month
WEATHERSTACK_API_KEY=your_key_here

# Postgres credentials (used by all services to talk to the DB)
POSTGRES_USER=db_user
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=db

# Superset session encryption key
# Generate with: openssl rand -base64 42
SUPERSET_SECRET_KEY=replace_with_random_string_at_least_42_chars_long
